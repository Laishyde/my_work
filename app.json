{
  "expo": {
    "name": "Eventim BR",
    "slug": "TicketMasterApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/eventin.png",
    "scheme": "ticketmasterapp",
    "splash": {
      "image": "./assets/images/eventin.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ticketmasterapp.app",
      "icon": "./assets/images/eventin.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/eventin.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.ticketmasterapp.app",
      "permissions": ["INTERNET", "ACCESS_NETWORK_STATE"]
    },
    "web": {
      "output": "static",
      "publicPath": "/",
      "favicon": "./assets/images/eventin.png",
      "title": "Eventim BR"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "0a16ec97-d94c-4894-8303-14895d2b88e5"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0a16ec97-d94c-4894-8303-14895d2b88e5"
    },
    "owner": "azume"
  },
  "web": {
    "output": "static",
    "publicPath": "/",
    "favicon": "./assets/images/eventin.png",
    "title": "Eventim BR"
  }
}
